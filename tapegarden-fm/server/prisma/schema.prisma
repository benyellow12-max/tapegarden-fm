// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  username  String   @unique
  password  String
  displayName String
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile     UserProfile?
  sessions    ListeningSession[]
  badges      UserBadge[]
  connections UserPlatformConnection[]
  privacySettings PrivacySettings?

  @@map("users")
}

model UserProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  bio             String?
  location        String?
  website         String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model PrivacySettings {
  id                    String   @id @default(cuid())
  userId                String   @unique
  showListeningHistory  Boolean  @default(true)
  showTopArtists        Boolean  @default(true)
  showTopGenres         Boolean  @default(true)
  showBadges            Boolean  @default(true)
  publicProfile         Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("privacy_settings")
}

model Track {
  id          String   @id @default(cuid())
  name        String
  artist      String
  album       String?
  durationMs  Int
  genre       String?
  imageUrl    String?
  externalUrl String?
  platform    MusicPlatform
  platformId  String   @unique

  sessions ListeningSession[]
  artists  Artist[]

  @@map("tracks")
}

model Artist {
  id          String   @id @default(cuid())
  name        String
  genre       String?
  imageUrl    String?
  externalUrl String?
  platform    MusicPlatform
  platformId  String   @unique

  tracks     Track[]
  sessions   ListeningSession[]

  @@map("artists")
}

model ListeningSession {
  id         String   @id @default(cuid())
  userId     String
  trackId    String
  artistId   String?
  playedAt   DateTime
  durationMs Int
  platform   MusicPlatform
  source     ListeningSource

  user   User   @relation(fields: [userId], references: [id])
  track  Track  @relation(fields: [trackId], references: [id])
  artist Artist? @relation(fields: [artistId], references: [id])

  @@map("listening_sessions")
}

model Badge {
  id          String        @id @default(cuid())
  name        String
  description String
  icon        String
  color       String
  rarity      BadgeRarity  @default(COMMON)
  criteria    Json
  createdAt   DateTime     @default(now())

  userBadges UserBadge[]

  @@map("badges")
}

model UserBadge {
  id          String   @id @default(cuid())
  userId      String
  badgeId     String
  earnedAt    DateTime?
  progress    Float    @default(0)
  isCompleted Boolean  @default(false)

  user  User  @relation(fields: [userId], references: [id])
  badge Badge @relation(fields: [badgeId], references: [id])

  @@unique([userId, badgeId])
  @@map("user_badges")
}

model UserPlatformConnection {
  id           String   @id @default(cuid())
  userId       String
  platform     MusicPlatform
  accessToken  String
  refreshToken String?
  expiresAt    DateTime
  connectedAt  DateTime @default(now())
  lastSyncedAt DateTime?
  isActive     Boolean  @default(true)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, platform])
  @@map("user_platform_connections")
}

enum MusicPlatform {
  SPOTIFY
  APPLE_MUSIC
  MANUAL
}

enum ListeningSource {
  STREAMING
  IMPORT
  MANUAL
}

enum BadgeRarity {
  COMMON
  UNCOMMON
  RARE
  EPIC
  LEGENDARY
}